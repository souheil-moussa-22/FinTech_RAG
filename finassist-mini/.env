APP_NAME=finassist-mini
APP_VERSION=0.1.0
DOCS_DIRECTORY=data/documents
CHROMA_DIRECTORY=data/chroma
CHROMA_COLLECTION=finassist_chunks
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
OLLAMA_URL=http://localhost:11434
LLM_MODEL=phi3:mini
RETRIEVAL_K=3
CHUNK_SIZE_WORDS=350
CHUNK_OVERLAP_WORDS=35
LLM_TIMEOUT_SECONDS=30
MAX_PROMPT_CHARS=6000
MAX_UPLOAD_SIZE_MB=25
UPLOAD_WRITE_CHUNK_BYTES=1048576
UPLOAD_MAX_CONCURRENCY=1
CHAT_MAX_CONCURRENCY=1
