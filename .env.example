APP_NAME=finassist-mini
APP_VERSION=0.1.0
DOCS_DIRECTORY=data/documents
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_URL=http://localhost:11434
LLM_MODEL=tinyllama
RETRIEVAL_K=3
CHUNK_SIZE_WORDS=350
CHUNK_OVERLAP_WORDS=35
LLM_TIMEOUT_SECONDS=90
MAX_PROMPT_CHARS=6000
MAX_UPLOAD_SIZE_MB=25
UPLOAD_WRITE_CHUNK_BYTES=1048576
UPLOAD_MAX_CONCURRENCY=1
CHAT_MAX_CONCURRENCY=1
ADMISSION_WAIT_SECONDS=1.0

# PostgreSQL Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fintech_rag
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
